# ─── REQUIRED ──────────────────────────────────────────────────────────
# Async Postgres URL. Use `postgresql+asyncpg://...` (not the default
# psycopg driver). For local docker-compose: postgres:5432. For managed
# Postgres (Neon, Supabase, RDS), use the connection string they give you.
DATABASE_URL=postgresql+asyncpg://edu:edu@localhost:5432/edu_homework

# Gemini API key. Get one at https://aistudio.google.com/apikey.
GEMINI_API_KEY=replace-me

# ─── MODEL ─────────────────────────────────────────────────────────────
# Pin to a stable release for production. `*-preview` and `*-exp` models
# can change behavior overnight.
GEMINI_MODEL=gemini-2.5-flash

# ─── AUTH ──────────────────────────────────────────────────────────────
# Comma-separated list of valid bearer tokens. Empty disables auth (every
# request accepted as user="anonymous"). Set this BEFORE going live.
#   Single token:   AUTH_TOKEN=s3cr3t-token-from-our-platform
#   Multi-tenant:   AUTH_TOKEN=svc-a-token,svc-b-token,manual-paste-token
AUTH_TOKEN=

# ─── QUEUE / WORKER ────────────────────────────────────────────────────
# Embedded worker concurrency (jobs running simultaneously per process).
# Set to 0 in API-only pods when running standalone workers separately.
WORKER_CONCURRENCY=4
# Polling interval (seconds) when the queue is empty.
WORKER_POLL_INTERVAL=2.0
# Max wall-clock per job before timeout/retry. HARD biology runs ~60-90s.
JOB_TIMEOUT_SECONDS=600
# Max retry attempts before terminal failure.
QUEUE_MAX_ATTEMPTS=3
# Queue depth that triggers 503 backpressure on /generate. Set 0 to disable.
QUEUE_BACKPRESSURE_LIMIT=50

# ─── GEMINI CONCURRENCY ───────────────────────────────────────────────
# Process-wide cap on simultaneous Gemini calls. Prevents rate-limit
# cascades when worker concurrency × parallel scheduler fan-out exceeds
# your account's RPM. Tune this to your tier (free=15 RPM, paid varies).
GEMINI_MAX_CONCURRENCY=8

# ─── UPLOAD LIMIT ─────────────────────────────────────────────────────
MAX_FILE_MB=50

# ─── DEV CONVENIENCE ──────────────────────────────────────────────────
# Expose /docs (Swagger). Disable in production.
ENABLE_DOCS=false
# CORS allow-list. `*` allows any origin (fine when API + SPA same-origin
# via the embedded SPA mount; tighten in production multi-origin setups).
ALLOW_ORIGINS=*
